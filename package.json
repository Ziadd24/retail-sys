{
  "name": "vet-monitor",
  "version": "1.0.0",
  "description": "Vet Pharmacy & Supply Chain Management System",
  "private": true,
  "scripts": {
    "migrate": "node --experimental-sqlite db/migrate.js",
    "migrate:down": "node --experimental-sqlite db/migrate.js down",
    "seed": "node --experimental-sqlite db/seed.js",
    "check:expiry": "node --experimental-sqlite workers/expiry-alert.js",
    "start": "node --experimental-sqlite server.js",
    "dev": "node --experimental-sqlite --watch server.js",
    "test": "node --test tests/e2e.test.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.21.0"
  }
}